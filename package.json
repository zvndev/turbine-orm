{
  "name": "turbine-orm",
  "version": "0.5.0",
  "description": "Postgres-native TypeScript ORM — single-query nested relations via json_agg, 1 dependency, 70KB",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/config.js",
      "require": "./dist/cjs/cli/config.js",
      "types": "./dist/cli/config.d.ts"
    },
    "./serverless": {
      "import": "./dist/serverless.js",
      "require": "./dist/cjs/serverless.js",
      "types": "./dist/serverless.d.ts"
    }
  },
  "main": "./dist/cjs/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "turbine": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "!dist/**/test",
    "!dist/**/*.js.map",
    "!dist/**/examples.*",
    "!dist/**/*.d.ts.map",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc && tsc --project tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "generate": "tsx src/cli/index.ts generate",
    "status": "tsx src/cli/index.ts status",
    "examples": "tsx examples/examples.ts",
    "test": "tsx --test src/test/*.test.ts",
    "test:unit": "tsx --test src/test/schema-builder.test.ts src/test/errors.test.ts src/test/stress.test.ts src/test/migrate.test.ts",
    "test:coverage": "c8 tsx --test src/test/schema-builder.test.ts src/test/errors.test.ts src/test/stress.test.ts src/test/migrate.test.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "prepublishOnly": "npm run build && npm run typecheck && npm run lint && npm run test:unit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.11",
    "c8": "^11.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "orm",
    "postgres",
    "postgresql",
    "typescript",
    "json-agg",
    "query-builder",
    "database",
    "sql",
    "turbine",
    "nested-queries",
    "prisma-alternative"
  ],
  "author": "ZVN DEV <dev@zvndev.com>",
  "license": "MIT",
  "homepage": "https://turbineorm.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/zvndev/turbine-orm.git"
  },
  "bugs": {
    "url": "https://github.com/zvndev/turbine-orm/issues"
  }
}
